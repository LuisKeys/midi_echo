# ============================================================================
# MIDI Output Configuration
# ============================================================================
# MIDI Echo uses OS-aware output pattern matching to automatically discover
# and select the appropriate MIDI output port for your system.
#
# APPROACH:
#   By default, the app enumerates available MIDI ports and matches them against
#   OS-specific patterns:
#     - macOS: ["Virtual Bus", "IAC Driver", "IAC"]
#     - Linux: ["VirMIDI", "TiMidity", "ALSA", "Midi Through"]
#     - Windows: ["loopMIDI", "Virtual", "MIDI Yoke"]
#
# OVERRIDE OPTIONS (in priority order):
#   1. MAC_OUTPUT    - Set on macOS to override default patterns
#   2. LINUX_OUTPUT  - Set on Linux to override default patterns
#   3. OUTPUT        - Set on other OSes to override default patterns
#   4. PREFER_OUTPUTS_OVERRIDE - Set on ANY OS (comma-separated list of port names)
#
# EXAMPLE:
#   MAC_OUTPUT="Virtual Bus 1"
#   LINUX_OUTPUT="VirMIDI 0-1"
#   PREFER_OUTPUTS_OVERRIDE="IAC Driver,Virtual Bus 1"
#
# On startup, the app will:
#   1. Check for explicit overrides (MAC_OUTPUT, LINUX_OUTPUT, OUTPUT, PREFER_OUTPUTS_OVERRIDE)
#   2. If found, try to match against available ports
#   3. If not found, use OS-specific default patterns
#   4. If still no match, print all available ports and exit with helpful message
#
# ============================================================================

# Uncomment ONE of these based on your system:

# macOS: Uncomment if you want to override default patterns
# MAC_OUTPUT="Virtual Bus 1"

# Linux: Uncomment if you want to override default patterns
# LINUX_OUTPUT="VirMIDI 0-1"

# Windows or generic: Uncomment if you want to override default patterns
# OUTPUT=

# Override for any OS: comma-separated list of preferred output port names
# (Do NOT use quotes around individual port names)
PREFER_OUTPUTS_OVERRIDE=VirMIDI 0-1, ESI MIDIMATE eX MIDI 1, Virtual Bus 1 

# ============================================================================
# Other Configuration
# ============================================================================

VERBOSE=false
LIST_PORTS=false
SHORT_PRESS_THRESHOLD=200
LONG_PRESS_THRESHOLD=500
LONG_PRESS_INCREMENT=1
HOLD_INCREMENT_RATE=50

# Audio device ID for metronome playback (numeric device ID or leave empty for default)
# Run with LIST_PORTS=true to see all available audio devices
# AUDIO_DEVICE=Scarlett 2i2 USB
